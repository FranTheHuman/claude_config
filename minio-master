INSTALACIÓN
────────────
  mkdir -p ~/.claude/skills/minio-ops ~/.claude/commands/minio
  cp minio-master.md ~/.claude/agents/
  cp SKILL.md ~/.claude/skills/minio-ops/
  cp commands/minio/*.md ~/.claude/commands/minio/

  claude
  /agents   # debe aparecer minio-master
  /help     # debe listar /minio:*


